{
  "version": 2,
  "builds": [
    {
      "src": "server/api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "server/api/(.*)",
      "dest": "server/api/app.js"
    },
    {
      "src": "server/api/(.*)",
      "dest": "server/api/embed.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
